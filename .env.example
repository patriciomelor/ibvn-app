# Configuración de Entorno Local
# Copia este archivo a .env.local e ingresa las credenciales reales

# Supabase (Obligatorio)
VITE_SUPABASE_URL="https://tu-proyecto.supabase.co"
VITE_SUPABASE_ANON_KEY="tu-anon-key-publica"

# Sentry (Opcional en desarrollo local, Obligatorio en Producción)
VITE_SENTRY_DSN=""

# PostHog (Opcional en desarrollo local, Obligatorio en Producción)
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://us.i.posthog.com"

# --- BACKEND / PIPELINE IA ---

# Supabase Service Role (Para que la API tenga permisos de admin sobre el bucket)
SUPABASE_SERVICE_ROLE_KEY=""

# OpenAI (Para Whisper - Transcripción)
OPENAI_API_KEY=""

# Anthropic (Para Claude - Generación de Texto)
ANTHROPIC_API_KEY=""
